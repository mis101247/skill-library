---
import { formatCategory, formatTag, tagSearchText } from '../utils/taxonomy';

interface Props {
  href: string;
  kind: string;
  title: string;
  description: string;
  category?: string;
  tags?: string[];
  thumbnailUrl?: string;
  thumbnailAlt?: string;
  thumbnailContainWhite?: boolean;
  showThumbnail?: boolean;
}

const {
  href,
  kind,
  title,
  description,
  category,
  tags = [],
  thumbnailUrl,
  thumbnailAlt,
  thumbnailContainWhite = false,
  showThumbnail = false,
} = Astro.props;
const formattedCategory = category ? formatCategory(category) : '';
const formattedTags = [...new Set(tags.slice(0, 4).map(formatTag))];
const thumbnailClass = [
  'content-card__thumbnail',
  thumbnailContainWhite ? 'content-card__thumbnail--contain-white' : '',
].filter(Boolean).join(' ');
---

<article
  class="content-card"
  data-library-item
  data-title={title.toLowerCase()}
  data-description={description.toLowerCase()}
  data-category={formattedCategory}
  data-tags={tagSearchText(tags ?? []).toLowerCase()}
>
  <a class="content-card__main" href={href}>
    {showThumbnail && thumbnailUrl && (
      <img
        class={thumbnailClass}
        src={thumbnailUrl}
        alt={thumbnailAlt ?? `${title} 縮圖`}
        loading="lazy"
        decoding="async"
      />
    )}
    <span class="content-card__kind">{kind}</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </a>
  {tags.length > 0 && (
    <div class="chip-row">
      {formattedTags.map((tag) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
    </div>
  )}
</article>

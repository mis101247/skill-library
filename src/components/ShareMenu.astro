---
interface Props {
  title: string;
  description: string;
  contentId: string;
  canonicalPath: string;
  coverImage?: string | null;
  placement?: string;
  trackingName?: string;
}

const {
  title,
  description,
  contentId,
  canonicalPath,
  coverImage,
  placement = 'detail_footer',
  trackingName = 'library_share',
} = Astro.props;
const siteOrigin = Astro.site ?? Astro.url.origin;
const siteDomain = new URL(siteOrigin).hostname;
const canonicalURL = new URL(canonicalPath, siteOrigin).toString();
---

<div
  class="share-menu"
  data-share-menu
  data-title={title}
  data-description={description}
  data-content-id={contentId}
  data-cover-image={coverImage || undefined}
  data-placement={placement}
  data-site-domain={siteDomain}
  data-tracking-name={trackingName}
  data-url={canonicalURL}
>
  <div class="share-copy">
    <p class="share-eyebrow">讀完覺得有幫助嗎？</p>
    <p class="share-description">分享給也會用得到的人，或存成社群卡片。</p>
  </div>
  <div class="share-actions">
    <button
      class="share-trigger"
      type="button"
      aria-haspopup="menu"
      aria-expanded="false"
      data-share-trigger
    >
      <span class="share-trigger-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <circle cx="18" cy="5" r="3" fill="none" stroke="currentColor" stroke-width="2" />
          <circle cx="6" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="2" />
          <circle cx="18" cy="19" r="3" fill="none" stroke="currentColor" stroke-width="2" />
          <path
            d="m8.6 10.6 6.8-4.1M8.6 13.4l6.8 4.1"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
          />
        </svg>
      </span>
      <span>分享這頁</span>
    </button>
    <div class="share-options" role="menu" hidden data-share-options>
      <button type="button" role="menuitem" data-share-card>產生圖文卡片</button>
      {
        coverImage && (
          <button type="button" role="menuitem" data-share-cover-card>
            產生含封面圖卡片
          </button>
        )
      }
      <button type="button" role="menuitem" data-share-link>複製分享連結</button>
    </div>
    <p class="share-status" aria-live="polite" data-share-status></p>
  </div>
  <div class="share-preview" role="dialog" aria-modal="true" aria-label="圖文卡片預覽" hidden data-share-preview>
    <div class="share-preview-backdrop" data-share-preview-close></div>
    <div class="share-preview-panel share-preview-panel-card">
      <div class="share-preview-header">
        <h2>圖文卡片預覽</h2>
        <button class="share-preview-close" type="button" aria-label="關閉預覽" data-share-preview-close>
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <img class="share-preview-image" alt="圖文卡片預覽" data-share-preview-image />
      <p class="share-preview-hint">iPhone：長按圖片，選「儲存到照片」</p>
      <div class="share-preview-actions">
        <button class="share-preview-secondary" type="button" data-share-preview-close>關閉</button>
        <button class="share-preview-primary" type="button" data-share-preview-download>下載 PNG</button>
      </div>
    </div>
  </div>
  <div class="share-preview" role="dialog" aria-modal="true" aria-label="分享文字預覽" hidden data-share-link-preview>
    <div class="share-preview-backdrop" data-share-link-close></div>
    <div class="share-preview-panel">
      <div class="share-preview-header">
        <h2>分享文字預覽</h2>
        <button class="share-preview-close" type="button" aria-label="關閉預覽" data-share-link-close>
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="share-link-text" tabindex="0" data-share-link-text></div>
      <div class="share-preview-actions">
        <button class="share-preview-secondary" type="button" data-share-link-close>先不用</button>
        <button class="share-preview-primary" type="button" data-share-link-copy>複製文字</button>
      </div>
    </div>
  </div>
</div>

<style>
  .share-menu {
    position: relative;
    box-sizing: border-box;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    width: 100%;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(var(--ink-rgb), 0.12);
    border-radius: 10px;
    background:
      radial-gradient(circle at 88% 18%, rgba(255, 243, 192, 0.72), transparent 36%),
      linear-gradient(135deg, rgba(250, 251, 252, 0.94), rgba(214, 236, 248, 0.56));
    box-shadow: var(--shadow);
  }

  .share-copy {
    min-width: 0;
  }

  .share-eyebrow {
    margin: 0 0 0.25rem;
    color: var(--ink);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .share-description {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .share-actions {
    position: relative;
    display: grid;
    justify-items: end;
    gap: 0.4rem;
  }

  .share-trigger,
  .share-options button {
    border: 1px solid rgba(var(--ink-rgb), 0.14);
    border-radius: 999px;
    background: var(--canvas);
    color: var(--ink);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: var(--shadow);
  }

  .share-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    gap: 0.45rem;
    padding: 0.55rem 0.95rem;
    background: linear-gradient(135deg, var(--sun), var(--honey));
  }

  .share-trigger-icon {
    display: inline-grid;
    width: 1.1rem;
    height: 1.1rem;
    place-items: center;
  }

  .share-trigger-icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .share-trigger:hover,
  .share-trigger:focus-visible,
  .share-options button:hover,
  .share-options button:focus-visible {
    border-color: rgba(var(--ink-rgb), 0.32);
    box-shadow: var(--shadow-strong);
  }

  .share-options {
    position: absolute;
    z-index: 10;
    top: calc(100% + 0.5rem);
    right: 0;
    box-sizing: border-box;
    display: grid;
    width: min(16rem, calc(100vw - 2rem));
    gap: 0.45rem;
    padding: 0.55rem;
    border: 1px solid rgba(var(--ink-rgb), 0.12);
    border-radius: 12px;
    background: rgba(250, 251, 252, 0.96);
    box-shadow: var(--shadow-strong);
    backdrop-filter: blur(12px);
  }

  .share-options[hidden] {
    display: none;
  }

  .share-options button {
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    background: var(--canvas);
    text-align: left;
  }

  .share-status {
    min-height: 1.2em;
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.4;
    text-align: right;
  }

  .share-preview {
    position: fixed;
    z-index: 1000;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .share-preview[hidden] {
    display: none;
  }

  .share-preview-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(32, 42, 51, 0.52);
    backdrop-filter: blur(10px);
  }

  .share-preview-panel {
    position: relative;
    box-sizing: border-box;
    display: grid;
    width: min(29rem, 100%);
    max-height: calc(100vh - 2rem);
    gap: 0.85rem;
    padding: 1rem;
    overflow: auto;
    border: 1px solid rgba(var(--ink-rgb), 0.12);
    border-radius: 12px;
    background: var(--canvas);
    box-shadow: 0 24px 60px rgba(32, 42, 51, 0.28);
  }

  .share-preview-panel-card {
    width: min(54rem, 100%);
  }

  .share-preview-header,
  .share-preview-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .share-preview-header h2 {
    margin: 0;
    color: var(--ink);
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .share-preview-close,
  .share-preview-secondary,
  .share-preview-primary {
    border: 1px solid rgba(var(--ink-rgb), 0.14);
    background: var(--canvas);
    color: var(--ink);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
  }

  .share-preview-close {
    display: inline-grid;
    width: 2rem;
    height: 2rem;
    padding: 0;
    place-items: center;
    border-radius: 999px;
    font-size: 1.35rem;
    line-height: 1;
  }

  .share-preview-image {
    display: block;
    width: 100%;
    aspect-ratio: 1200 / 650;
    border: 1px solid rgba(var(--ink-rgb), 0.12);
    border-radius: 8px;
    background: var(--mist);
    object-fit: contain;
  }

  .share-preview-hint {
    margin: -0.25rem 0 0;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .share-link-text {
    box-sizing: border-box;
    width: 100%;
    min-height: 12rem;
    max-height: 16rem;
    padding: 0.9rem;
    overflow: auto;
    border: 1px solid rgba(var(--ink-rgb), 0.12);
    border-radius: 8px;
    background: rgba(214, 236, 248, 0.28);
    color: var(--ink);
    font: inherit;
    font-size: 0.92rem;
    line-height: 1.65;
    overflow-wrap: anywhere;
    user-select: text;
    white-space: pre-wrap;
  }

  .share-preview-secondary,
  .share-preview-primary {
    min-height: 2.65rem;
    padding: 0.6rem 0.95rem;
    border-radius: 999px;
  }

  .share-preview-primary {
    background: linear-gradient(135deg, var(--sun), var(--honey));
  }

  .share-preview-close:hover,
  .share-preview-close:focus-visible,
  .share-preview-secondary:hover,
  .share-preview-secondary:focus-visible,
  .share-preview-primary:hover,
  .share-preview-primary:focus-visible {
    border-color: rgba(var(--ink-rgb), 0.32);
    box-shadow: var(--shadow-strong);
  }

  @media (max-width: 520px) {
    .share-menu {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .share-actions,
    .share-trigger {
      width: 100%;
    }

    .share-actions {
      justify-items: stretch;
    }

    .share-options {
      position: static;
      width: 100%;
    }

    .share-status {
      text-align: left;
    }

    .share-preview-actions {
      display: grid;
      grid-template-columns: 1fr;
      justify-items: stretch;
    }

    .share-preview-secondary,
    .share-preview-primary {
      width: 100%;
    }
  }
</style>

<script is:inline>
  (() => {
    const WIDTH = 1200;
    const HEIGHT = 650;
    const UTM_CAMPAIGN = 'one_click_share';
    const UTM_MEDIUM = 'social';

    const colors = {
      canvas: '#FAFBFC',
      honey: '#FFDF90',
      ink: '#3A6080',
      leaf: '#D8EDD8',
      lotus: '#FFD6DC',
      mist: '#D6ECF8',
      quartz: '#E2EAF0',
      sky: '#B8D8F0',
      sun: '#FFF3C0',
    };

    const menus = document.querySelectorAll('[data-share-menu]');

    menus.forEach((menu) => {
      const trigger = menu.querySelector('[data-share-trigger]');
      const options = menu.querySelector('[data-share-options]');
      const cardButton = menu.querySelector('[data-share-card]');
      const coverCardButton = menu.querySelector('[data-share-cover-card]');
      const linkButton = menu.querySelector('[data-share-link]');
      const status = menu.querySelector('[data-share-status]');
      const preview = menu.querySelector('[data-share-preview]');
      const previewImage = menu.querySelector('[data-share-preview-image]');
      const previewDownload = menu.querySelector('[data-share-preview-download]');
      const previewCloseButtons = menu.querySelectorAll('[data-share-preview-close]');
      const linkPreview = menu.querySelector('[data-share-link-preview]');
      const linkText = menu.querySelector('[data-share-link-text]');
      const linkCopy = menu.querySelector('[data-share-link-copy]');
      const linkCloseButtons = menu.querySelectorAll('[data-share-link-close]');
      if (!trigger || !options || !cardButton || !linkButton || !status || !preview || !previewImage || !previewDownload || !linkPreview || !linkText || !linkCopy) return;

      let previewBlob;
      let previewFileName = '';
      let previewObjectUrl = '';
      let previewShareType = 'card';

      trigger.addEventListener('click', () => {
        const isOpen = !options.hidden;
        options.hidden = isOpen;
        trigger.setAttribute('aria-expanded', String(!isOpen));
        recordShare(menu, 'menu_open', 'button');
      });

      cardButton.addEventListener('click', async () => {
        await openCardPreview(false);
      });

      coverCardButton?.addEventListener('click', async () => {
        await openCardPreview(true);
      });

      async function openCardPreview(includeCover) {
        options.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        setStatus(status, '正在產生卡片...');
        try {
          closeLinkPreview(false);
          const shareType = includeCover ? 'cover_card' : 'card';
          const previewCard = await shareCard(menu, includeCover);
          if (previewObjectUrl) URL.revokeObjectURL(previewObjectUrl);
          previewBlob = previewCard.blob;
          previewFileName = previewCard.fileName;
          previewShareType = shareType;
          previewObjectUrl = URL.createObjectURL(previewBlob);
          previewImage.src = previewObjectUrl;
          preview.hidden = false;
          document.documentElement.style.overflow = 'hidden';
          previewDownload.focus();
          recordShare(menu, shareType, 'preview_open');
          setStatus(status, '卡片預覽已產生');
        } catch (error) {
          if (!includeCover) console.error(error);
          const message = includeCover
            ? '封面圖目前不能匯出 PNG，請先改用一般圖卡'
            : '無法產生卡片，請改用複製連結';
          setStatus(status, message, 7200);
        }
      }

      linkButton.addEventListener('click', () => {
        options.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
        try {
          closePreview(false);
          linkText.textContent = buildShareText(menu);
          linkPreview.hidden = false;
          document.documentElement.style.overflow = 'hidden';
          linkCopy.focus();
          recordShare(menu, 'link', 'preview_open');
          setStatus(status, '分享文字已準備好');
        } catch (error) {
          console.error(error);
          setStatus(status, '無法產生分享文字，請複製網址列');
        }
      });

      previewDownload.addEventListener('click', () => {
        if (!previewBlob || !previewFileName) return;
        downloadBlob(previewBlob, previewFileName);
        recordShare(menu, previewShareType, 'download_png');
        setStatus(status, '已下載 PNG');
        closePreview();
      });

      previewCloseButtons.forEach((button) => {
        button.addEventListener('click', () => {
          recordShare(menu, previewShareType, 'preview_close');
          closePreview(true);
        });
      });

      linkCopy.addEventListener('click', async () => {
        try {
          await copyText(linkText.textContent || '', linkText);
          recordShare(menu, 'link', 'copy_text');
          setStatus(status, '已複製文字');
          closeLinkPreview(true);
        } catch (error) {
          console.error(error);
          setStatus(status, '已選取文字，請手動複製');
        }
      });

      linkCloseButtons.forEach((button) => {
        button.addEventListener('click', () => {
          recordShare(menu, 'link', 'preview_close');
          closeLinkPreview(true);
        });
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        if (!preview.hidden) {
          recordShare(menu, previewShareType, 'preview_close');
          closePreview(true);
          return;
        }
        if (!linkPreview.hidden) {
          recordShare(menu, 'link', 'preview_close');
          closeLinkPreview(true);
        }
      });

      document.addEventListener('click', (event) => {
        if (menu.contains(event.target)) return;
        options.hidden = true;
        trigger.setAttribute('aria-expanded', 'false');
      });

      function closePreview(shouldFocus = true) {
        preview.hidden = true;
        previewImage.removeAttribute('src');
        document.documentElement.style.overflow = '';
        if (previewObjectUrl) {
          URL.revokeObjectURL(previewObjectUrl);
          previewObjectUrl = '';
        }
        previewBlob = undefined;
        previewFileName = '';
        previewShareType = 'card';
        if (shouldFocus) trigger.focus();
      }

      function closeLinkPreview(shouldFocus = true) {
        linkPreview.hidden = true;
        linkText.textContent = '';
        document.documentElement.style.overflow = '';
        if (shouldFocus) trigger.focus();
      }
    });

    async function shareCard(menu, includeCover) {
      const blob = await renderShareCard(menu, includeCover);
      const suffix = includeCover ? 'share-card-cover' : 'share-card';
      const fileName = `${slugify(menu.dataset.contentId || 'keyo-library')}-${suffix}.png`;
      return { blob, fileName };
    }

    function buildShareText(menu) {
      const shareUrl = buildShareUrl(menu, 'share_link');
      return [
        menu.dataset.title || document.title,
        menu.dataset.description || '',
        shareUrl,
      ].filter(Boolean).join('\n\n');
    }

    function buildShareUrl(menu, source) {
      const url = new URL(menu.dataset.url || window.location.href);
      url.searchParams.set('utm_source', source);
      url.searchParams.set('utm_medium', UTM_MEDIUM);
      url.searchParams.set('utm_campaign', UTM_CAMPAIGN);
      url.searchParams.set('utm_content', menu.dataset.contentId || 'unknown');
      url.searchParams.set('utm_term', menu.dataset.placement || 'detail_footer');
      return url.toString();
    }

    function recordShare(menu, shareType, action) {
      const detail = {
        action,
        content_id: menu.dataset.contentId || 'unknown',
        placement: menu.dataset.placement || 'detail_footer',
        share_type: shareType,
      };
      window.dispatchEvent(new CustomEvent('keyo:share', { detail }));
      if (typeof window.umami?.track === 'function') {
        window.umami.track(menu.dataset.trackingName || 'library_share', detail);
      }
    }

    function setStatus(status, message, duration = 3600) {
      status.textContent = message;
      if (!message) return;
      window.setTimeout(() => {
        if (status.textContent === message) status.textContent = '';
      }, duration);
    }

    async function renderShareCard(menu, includeCover) {
      const canvas = document.createElement('canvas');
      canvas.width = WIDTH;
      canvas.height = HEIGHT;
      const ctx = canvas.getContext('2d');
      if (!ctx) throw new Error('Canvas is unavailable.');

      drawCardBackground(ctx);
      if (includeCover && menu.dataset.coverImage) {
        const coverImage = await loadImage(menu.dataset.coverImage);
        drawCoverShareCard(ctx, menu, coverImage);
      } else {
        drawTextShareCard(ctx, menu);
      }
      drawSiteDomain(ctx, menu);

      return canvasToBlob(canvas);
    }

    function drawTextShareCard(ctx, menu) {
      drawBrandMark(ctx, 92, 52, 92);

      ctx.fillStyle = colors.ink;
      ctx.textBaseline = 'top';
      ctx.font = '700 66px "Noto Serif TC", Georgia, serif';
      const titleLines = wrapText(ctx, menu.dataset.title || document.title, 900, 2);
      drawLines(ctx, titleLines, 92, 165, 78);

      ctx.font = '400 36px "Noto Sans TC", system-ui, sans-serif';
      ctx.fillStyle = 'rgba(58, 96, 128, 0.82)';
      const descY = 190 + titleLines.length * 78;
      const descLines = wrapText(ctx, menu.dataset.description || '', 1040, 3);
      drawLines(ctx, descLines, 96, descY, 54);

      drawCornerMotifs(ctx);
    }

    function drawCoverShareCard(ctx, menu, coverImage) {
      drawCoverFrame(ctx, coverImage, 628, 96, 500, 360);
      drawBrandMark(ctx, 78, 58, 82);

      ctx.fillStyle = colors.ink;
      ctx.textBaseline = 'top';
      ctx.font = '700 52px "Noto Serif TC", Georgia, serif';
      const titleLines = wrapText(ctx, menu.dataset.title || document.title, 500, 3);
      drawLines(ctx, titleLines, 78, 164, 62);

      ctx.font = '400 29px "Noto Sans TC", system-ui, sans-serif';
      ctx.fillStyle = 'rgba(58, 96, 128, 0.82)';
      const descY = 188 + titleLines.length * 62;
      const descLines = wrapText(ctx, menu.dataset.description || '', 510, 3);
      drawLines(ctx, descLines, 80, descY, 43);
    }

    function drawCardBackground(ctx) {
      ctx.fillStyle = colors.canvas;
      ctx.fillRect(0, 0, WIDTH, HEIGHT);

      drawWash(ctx, 130, 118, 340, colors.mist, 0.64);
      drawWash(ctx, 1000, 128, 320, colors.sky, 0.32);
      drawWash(ctx, 1060, 565, 280, colors.leaf, 0.4);
      drawWash(ctx, 280, 610, 250, colors.lotus, 0.24);
      drawWash(ctx, 655, 326, 390, colors.sun, 0.52);

      ctx.globalAlpha = 0.16;
      ctx.fillStyle = colors.ink;
      for (let index = 0; index < 220; index += 1) {
        const x = (index * 79) % WIDTH;
        const y = (index * 43) % HEIGHT;
        ctx.fillRect(x, y, 1, 1);
      }
      ctx.globalAlpha = 1;
    }

    function drawCoverFrame(ctx, image, x, y, maxWidth, maxHeight) {
      const frame = fitImageFrame(image, x, y, maxWidth, maxHeight);

      ctx.save();
      ctx.shadowColor = 'rgba(32, 42, 51, 0.18)';
      ctx.shadowBlur = 28;
      ctx.shadowOffsetY = 16;
      ctx.fillStyle = 'rgba(250, 251, 252, 0.92)';
      roundRect(ctx, frame.x - 14, frame.y - 14, frame.width + 28, frame.height + 28, 24);
      ctx.fill();
      ctx.restore();

      ctx.save();
      roundRect(ctx, frame.x, frame.y, frame.width, frame.height, 18);
      ctx.clip();
      drawImageContain(ctx, image, frame.x, frame.y, frame.width, frame.height);
      ctx.restore();

      ctx.strokeStyle = 'rgba(58, 96, 128, 0.18)';
      ctx.lineWidth = 2;
      roundRect(ctx, frame.x, frame.y, frame.width, frame.height, 18);
      ctx.stroke();
    }

    function fitImageFrame(image, x, y, maxWidth, maxHeight) {
      const imageWidth = image.naturalWidth || image.width;
      const imageHeight = image.naturalHeight || image.height;
      const imageRatio = imageWidth / imageHeight || 1;
      const maxRatio = maxWidth / maxHeight;
      let width = maxWidth;
      let height = maxHeight;

      if (imageRatio > maxRatio) {
        height = width / imageRatio;
      } else {
        width = height * imageRatio;
      }

      return {
        x: x + (maxWidth - width) / 2,
        y: y + (maxHeight - height) / 2,
        width,
        height,
      };
    }

    function drawImageContain(ctx, image, x, y, width, height) {
      ctx.fillStyle = colors.canvas;
      ctx.fillRect(x, y, width, height);
      ctx.drawImage(image, x, y, width, height);
    }

    function drawWash(ctx, x, y, radius, color, alpha) {
      const gradient = ctx.createRadialGradient(x, y, 0, x, y, radius);
      gradient.addColorStop(0, hexToRgba(color, alpha));
      gradient.addColorStop(1, hexToRgba(color, 0));
      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.fill();
    }

    function drawBrandMark(ctx, x, y, size) {
      ctx.save();
      ctx.translate(x, y);
      ctx.fillStyle = colors.mist;
      roundRect(ctx, 0, 0, size, size, 24);
      ctx.fill();

      ctx.fillStyle = colors.sun;
      ctx.beginPath();
      ctx.arc(size * 0.72, size * 0.25, size * 0.16, 0, Math.PI * 2);
      ctx.fill();

      ctx.strokeStyle = colors.ink;
      ctx.lineWidth = 8;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';
      ctx.beginPath();
      ctx.moveTo(size * 0.34, size * 0.76);
      ctx.lineTo(size * 0.34, size * 0.25);
      ctx.moveTo(size * 0.37, size * 0.5);
      ctx.bezierCurveTo(size * 0.5, size * 0.44, size * 0.62, size * 0.34, size * 0.72, size * 0.22);
      ctx.moveTo(size * 0.48, size * 0.5);
      ctx.bezierCurveTo(size * 0.58, size * 0.58, size * 0.68, size * 0.68, size * 0.77, size * 0.8);
      ctx.stroke();

      ctx.fillStyle = colors.leaf;
      ctx.beginPath();
      ctx.moveTo(size * 0.7, size * 0.78);
      ctx.bezierCurveTo(size * 0.84, size * 0.72, size * 0.9, size * 0.62, size * 0.91, size * 0.5);
      ctx.bezierCurveTo(size * 0.77, size * 0.51, size * 0.68, size * 0.63, size * 0.7, size * 0.78);
      ctx.fill();
      ctx.restore();
    }

    function drawCornerMotifs(ctx) {
      ctx.strokeStyle = 'rgba(58, 96, 128, 0.22)';
      ctx.lineWidth = 3;
      ctx.setLineDash([10, 16]);
      ctx.beginPath();
      ctx.moveTo(910, 64);
      ctx.bezierCurveTo(1030, 118, 1088, 228, 1044, 342);
      ctx.stroke();
      ctx.setLineDash([]);

      [
        [880, 68, colors.leaf],
        [1002, 178, colors.lotus],
        [1034, 318, colors.honey],
      ].forEach(([x, y, color]) => {
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(x, y, 19, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = 'rgba(58, 96, 128, 0.35)';
        ctx.stroke();
      });
    }

    function wrapText(ctx, text, maxWidth, maxLines) {
      const tokens = tokenizeText(text);
      const lines = [];
      let line = '';
      let didTruncate = false;

      for (let index = 0; index < tokens.length; index += 1) {
        const token = tokens[index];
        if (token === ' ' && !line) continue;

        const next = line ? `${line}${token}` : token.trimStart();
        if (ctx.measureText(next.trimEnd()).width <= maxWidth) {
          line = next;
          continue;
        }

        if (line) {
          lines.push(line.trimEnd());
          if (lines.length === maxLines) {
            didTruncate = hasRemainingText(tokens, index);
            line = '';
            break;
          }

          const nextLine = token.trimStart();
          if (!nextLine) {
            line = '';
            continue;
          }
          if (ctx.measureText(nextLine).width <= maxWidth) {
            line = nextLine;
            continue;
          }

          lines.push(trimToWidth(ctx, nextLine, maxWidth));
          didTruncate = hasRemainingText(tokens, index + 1);
          line = '';
          break;
        }

        lines.push(trimToWidth(ctx, token.trim(), maxWidth));
        didTruncate = hasRemainingText(tokens, index + 1);
        line = '';
        break;
      }

      if (line.trim() && lines.length < maxLines) {
        lines.push(line.trimEnd());
      } else if (line.trim()) {
        didTruncate = true;
      }

      if (didTruncate && lines.length) {
        lines[lines.length - 1] = trimToWidth(ctx, lines[lines.length - 1], maxWidth);
      }

      return lines;
    }

    function trimToWidth(ctx, text, maxWidth) {
      const ellipsis = '...';
      let result = text.trimEnd();
      while (result.length > 1 && ctx.measureText(`${result}${ellipsis}`).width > maxWidth) {
        result = result.slice(0, -1).trimEnd();
      }
      return `${result}${ellipsis}`;
    }

    function tokenizeText(text) {
      const tokens = [];
      let latinBuffer = '';
      const normalized = text.replace(/\s+/g, ' ').trim();

      Array.from(normalized).forEach((char) => {
        if (char === ' ') {
          flushLatin();
          if (tokens[tokens.length - 1] !== ' ') tokens.push(' ');
          return;
        }

        if (isLatinTokenChar(char)) {
          latinBuffer += char;
          return;
        }

        flushLatin();
        tokens.push(char);
      });

      flushLatin();
      return tokens;

      function flushLatin() {
        if (!latinBuffer) return;
        tokens.push(latinBuffer);
        latinBuffer = '';
      }
    }

    function isLatinTokenChar(char) {
      return /[A-Za-z0-9@#:/._?=&%+\-',]/.test(char);
    }

    function hasRemainingText(tokens, startIndex) {
      return tokens.slice(startIndex).some((token) => token.trim().length > 0);
    }

    function loadImage(src) {
      return new Promise((resolve, reject) => {
        const image = new Image();
        image.crossOrigin = 'anonymous';
        image.decoding = 'async';
        image.addEventListener('load', () => resolve(image), { once: true });
        image.addEventListener('error', () => reject('cover_image_unavailable'), { once: true });
        image.src = buildCoverImageURL(src);
      });
    }

    function buildCoverImageURL(src) {
      if (src.startsWith('data:') || src.startsWith('blob:')) return src;
      const url = new URL(src, window.location.href);
      url.searchParams.set('share_card_cors', '1');
      return url.toString();
    }

    function canvasToBlob(canvas) {
      return new Promise((resolve, reject) => {
        try {
          canvas.toBlob((blob) => {
            if (blob) resolve(blob);
            else reject(new Error('Unable to export PNG.'));
          }, 'image/png');
        } catch (error) {
          reject(error);
        }
      });
    }

    function drawLines(ctx, lines, x, y, lineHeight) {
      lines.forEach((line, index) => {
        ctx.fillText(line, x, y + index * lineHeight);
      });
    }

    function drawSiteDomain(ctx, menu) {
      const domain = menu.dataset.siteDomain || new URL(menu.dataset.url || window.location.href).hostname;
      if (!domain) return;

      ctx.save();
      ctx.font = '600 26px "Noto Sans TC", system-ui, sans-serif';
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      const paddingX = 20;
      const labelHeight = 46;
      const x = WIDTH - 78;
      const y = HEIGHT - 54;
      const labelWidth = ctx.measureText(domain).width + paddingX * 2;

      ctx.fillStyle = 'rgba(250, 251, 252, 0.76)';
      roundRect(ctx, x - labelWidth, y - labelHeight / 2, labelWidth, labelHeight, 23);
      ctx.fill();

      ctx.fillStyle = 'rgba(58, 96, 128, 0.78)';
      ctx.fillText(domain, x - paddingX, y);
      ctx.restore();
    }

    function roundRect(ctx, x, y, width, height, radius) {
      const r = Math.min(radius, width / 2, height / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + width - r, y);
      ctx.quadraticCurveTo(x + width, y, x + width, y + r);
      ctx.lineTo(x + width, y + height - r);
      ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
      ctx.lineTo(x + r, y + height);
      ctx.quadraticCurveTo(x, y + height, x, y + height - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath();
    }

    function hexToRgba(hex, alpha) {
      const value = hex.replace('#', '');
      const red = Number.parseInt(value.slice(0, 2), 16);
      const green = Number.parseInt(value.slice(2, 4), 16);
      const blue = Number.parseInt(value.slice(4, 6), 16);
      return `rgba(${red}, ${green}, ${blue}, ${alpha})`;
    }

    async function copyText(value, fallbackElement) {
      selectCopyFallback(fallbackElement, value);

      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(value);
          return;
        }
      } catch (error) {
        // Fall back to the selected preview text below.
      }

      if (fallbackElement && document.execCommand?.('copy')) return;
      throw new Error('Clipboard is unavailable.');
    }

    function selectCopyFallback(element, value) {
      if (!element) return;
      element.focus?.();
      if (element.select) {
        element.select();
        element.setSelectionRange?.(0, value.length);
        return;
      }

      const selection = window.getSelection?.();
      if (!selection || !document.createRange) return;
      const range = document.createRange();
      range.selectNodeContents(element);
      selection.removeAllRanges();
      selection.addRange(range);
    }

    function downloadBlob(blob, fileName) {
      const href = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = href;
      link.download = fileName;
      document.body.append(link);
      link.click();
      link.remove();
      window.setTimeout(() => URL.revokeObjectURL(href), 1000);
    }

    function slugify(value) {
      return value
        .toLowerCase()
        .replace(/[^a-z0-9-]+/g, '-')
        .replace(/^-+|-+$/g, '')
        || 'keyo-library';
    }
  })();
</script>

---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import ShareMenu from '../../components/ShareMenu.astro';
import TagList from '../../components/TagList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatCardKind } from '../../utils/content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.id },
    props: guide,
  }));
}

type Props = CollectionEntry<'guides'>;
const guide = Astro.props;
const { Content } = await render(guide);
const skills = (await getCollection('skills')).filter((skill) =>
  guide.data.relatedSkills.includes(skill.id),
);
---

<BaseLayout
  title={guide.data.title}
  description={guide.data.description}
  image={guide.data.coverImage}
  width="article"
>
  <article class="stack">
    <header class="hero">
      <div class="meta-row">
        <span class="meta-pill">{guide.data.difficulty}</span>
        {guide.data.timeEstimate && <span class="meta-pill">{guide.data.timeEstimate}</span>}
      </div>
      <h1>{guide.data.title}</h1>
      <p>{guide.data.description}</p>
      <TagList tags={guide.data.tags} />
    </header>

    {guide.data.coverImage && (
      <img
        class="guide-cover"
        src={guide.data.coverImage}
        alt={guide.data.coverImageAlt || guide.data.title}
        width="1536"
        height="1024"
        decoding="async"
      />
    )}

    <section class="grid grid--two">
      <div class="panel stack">
        <h2>學完會知道</h2>
        <ul>
          {guide.data.learningGoals.map((goal) => <li>{goal}</li>)}
        </ul>
      </div>
      <div class="panel stack">
        <h2>開始前先準備</h2>
        <ul>
          {guide.data.prerequisites.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="prose">
      <Content />
    </section>

    {skills.length > 0 && (
      <section class="section">
        <div class="section-header">
          <div>
            <h2>相關 Skill</h2>
            <p>讀完後可以直接點進去複製來試的本地 Skill。</p>
          </div>
        </div>
        <div class="grid">
          {skills.map((skill) => (
            <ContentCard
              href={`/skills/${skill.id}/`}
              kind={formatCardKind(skill.data.entryType, skill.data.featured)}
              title={skill.data.title}
              description={skill.data.description}
              category={skill.data.category}
              tags={skill.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    <ShareMenu
      title={guide.data.title}
      description={guide.data.description}
      contentId={`guide-${guide.id}`}
      canonicalPath={`/guides/${guide.id}/`}
      coverImage={guide.data.coverImage}
      placement="guide_detail_footer"
      trackingName="skill_library_share"
    />
  </article>
</BaseLayout>

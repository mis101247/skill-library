---
import { getCollection } from 'astro:content';
import SkillListPage from '../../../components/SkillListPage.astro';
import { sortFeaturedFirst } from '../../../utils/content';

const pageSize = 60;
const allSkills = sortFeaturedFirst(await getCollection('skills'));
const totalPages = Math.max(1, Math.ceil(allSkills.length / pageSize));

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  const pageCount = Math.max(1, Math.ceil(skills.length / 60));
  return Array.from({ length: Math.max(0, pageCount - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: String(page) },
      props: { page },
    };
  });
}

const currentPage = Number(Astro.props.page);
const pageSkills = allSkills.slice((currentPage - 1) * pageSize, currentPage * pageSize);
---

<SkillListPage
  skills={pageSkills}
  allSkills={allSkills}
  currentPage={currentPage}
  totalPages={totalPages}
  pageSize={pageSize}
/>

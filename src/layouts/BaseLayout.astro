---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  width?: 'default' | 'article' | 'wide';
}

const { title, description, image, width = 'default' } = Astro.props;
const shellClass = {
  default: 'page-shell',
  article: 'page-shell page-shell--article',
  wide: 'page-shell page-shell--wide',
}[width];
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    <Header />
    <main class={shellClass}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
